      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Returns latest stable version + dist-tags; the lastversion-equivalent convenience endpoint, cheap to build from tier-1 registry data, and makes the API self-sufficient without a second dependency.",
      "id": "docs_breaking_change_api_spec_resolve_endpoint",
      "community": 2,
      "norm_label": "/v1/resolve endpoint"
    },
    {
