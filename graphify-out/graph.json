      "source_file": "breaking-change-api-spec.md",
      "source_location": "\u00a79",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Default v1 hosting: single small VM/container + managed Postgres, optimizing for fastest time-to-working-product with least setup surface; workload is I/O-bound not GPU-bound, under $50/month at low volume, and cost scales with diff computation rather than request volume since most requests are cache hits.",
      "id": "docs_breaking_change_api_spec_paas_hosting",
      "community": 5,
      "norm_label": "paas hosting plan (fly/render/railway + neon)"
    },
